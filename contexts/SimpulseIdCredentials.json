{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "simpulseid": "https://schema.ascs.digital/SimpulseIdCredentials/v1#",
    "gx": "https://w3id.org/gaia-x/2411#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "simpulseid:LegalForm": {
      "@id": "simpulseid:LegalForm",
      "@context": {
        "@type": "xsd:string",
        "@vocab": "http://example.org/legalForms#",
        "LLC": "LLC",
        "Corporation": "Corporation",
        "LimitedPartnership": "Limited Partnership",
        "NonprofitCorporation": "Nonprofit Corporation",
        "GmbH": "GmbH",
        "AG": "AG",
        "Einzelunternehmen": "Einzelunternehmen",
        "GbR": "GbR",
        "OHG": "OHG",
        "KG": "KG",
        "UG": "UG",
        "SoleTrader": "Sole Trader",
        "UnincorporatedAssociation": "Unincorporated Association",
        "Partnership": "Partnership",
        "Trust": "Trust",
        "LimitedCompany": "Limited Company",
        "LLP": "LLP",
        "CIC": "CIC",
        "CIO": "CIO",
        "CooperativeSociety": "Cooperative Society",
        "BenCom": "BenCom",
        "other": "other"
      }
    },
    "simpulseid:Issuer": {
      "@id": "simpulseid:Issuer",
      "@context": {
        "member": {
          "@id": "schema:member",
          "@type": "@id"
        }
      }
    },
    "simpulseid:Participant": {
      "@id": "simpulseid:Participant",
      "rdfs:comment": "Participant entity representing a legal person or organization, compliant with mandatory Gaia-X standards for gx:LegalPerson.",
      "@context": {
        "@type": [
          "gx:LegalPerson",
          "schema:Organization"
        ],
        "id": "@id",
        "legalName": "gx:legalName",
        "legalForm": "simpulseid:LegalForm",
        "headquartersAddress": {
          "@id": "gx:headquartersAddress",
          "@type": "gx:Address"
        },
        "legalAddress": {
          "@id": "gx:legalAddress",
          "@type": "gx:Address"
        },
        "registrationNumber": {
          "@id": "gx:registrationNumber",
          "@type": "gx:VatID"
        },
        "duns": "schema:duns",
        "email": "schema:email",
        "website": "schema:url",
        "termsOfSimpulseId": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Terms and conditions for SimpulseID application.",
          "@container": "@set"
        }
      }
    },
    "simpulseid:AscsBaseMembership": {
      "@id": "simpulseid:AscsBaseMembership",
      "rdfs:comment": "ASC(S e.V. Base membership entity. A revoked member credential type means no membership status.",
      "@context": {
        "@type": [
          "gx:LegalPerson",
          "schema:Organization"
        ],
        "id": "@id",
        "memberOf": {
          "@id": "schema:memberOf",
          "@type": "@id"
        },
        "memberSince": {
          "@id": "schema:memberSince",
          "@type": "xsd:date"
        },
        "termsAndConditions": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Terms and conditions for the base membership.",
          "@container": "@set"
        }
      }
    },
    "simpulseid:AscsEnvitedMembership": {
      "@id": "simpulseid:AscsEnvitedMembership",
      "rdfs:comment": "ASC(S e.V. ENVITED membership entity. A revoked member credential type means no membership status.",
      "@context": {
        "@type": [
          "gx:LegalPerson",
          "schema:Organization"
        ],
        "id": "@id",
        "memberOf": {
          "@id": "schema:memberOf",
          "@type": "@id"
        },
        "memberSince": {
          "@id": "schema:memberSince",
          "@type": "xsd:date"
        },
        "termsAndConditions": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Terms and conditions for the Envited membership.",
          "@container": "@set"
        }
      }
    },
    "simpulseid:Administrator": {
      "@id": "simpulseid:Administrator",
      "rdfs:comment": "Administrator entity representing a natural person, compliant with mandatory Gaia-X standards for gx:NaturalPerson.",
      "@context": {
        "@type": [
          "gx:NaturalPerson",
          "schema:Person"
        ],
        "id": "@id",
        "memberOf": {
          "@id": "schema:memberOf",
          "@type": "@id"
        },
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",
        "address": "gx:Address",
        "termsAndConditions": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Privacy policy for the administrator.",
          "@container": "@set"
        }
      }
    },
    "simpulseid:User": {
      "@id": "simpulseid:User",
      "rdfs:comment": "User entity representing a natural person, compliant with mandatory Gaia-X standards for gx:NaturalPerson.",
      "@context": {
        "@type": [
          "gx:NaturalPerson",
          "schema:Person"
        ],
        "id": "@id",
        "memberOf": {
          "@id": "schema:memberOf",
          "@type": "@id"
        },
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",
        "termsAndConditions": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Privacy policy for the user.",
          "@container": "@set"
        }
      }
    },
    "gx:Address": {
      "@context": {
        "streetAddress": "schema:streetAddress",
        "postalCode": "schema:postalCode",
        "addressLocality": "schema:addressLocality",
        "countrySubdivisionCode": "gx:countrySubdivisionCode",
        "country": "schema:addressCountry"
      }
    },
    "gx:VatID": {
      "@context": {
        "countryCode": {
          "@id": "gx:countryCode",
          "@type": "xsd:string"
        },
        "vatID": {
          "@id": "gx:vatID",
          "@type": "xsd:string"
        }
      }
    }
  }
}
