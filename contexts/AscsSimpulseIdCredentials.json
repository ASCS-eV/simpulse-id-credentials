{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "ascs": "https://schema.ascs.digital/SimpulseId/v1#",
    "gx": "https://w3id.org/gaia-x/2411#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "ascs:SimpulseIdCredential": {
      "@id": "ascs:SimpulseIdCredential",
      "rdfs:comment": "Credential issued for Simpulse ID participants.",
      "@context": {
        "@protected": true
      }
    },

    "CRSetEntry": {
      "@id": "ascs:CRSetEntry",
      "rdfs:comment": "Index in the revocation registry according to the specification in https://arxiv.org/abs/2501.17089.",
      "@context": {
        "@protected": true,

        "id": "@id",
        "type": "@type",

        "statusPurpose": "https://www.w3.org/ns/credentials/status#statusPurpose"
      }
    },

    "ascs:LegalForm": {
      "@id": "ascs:LegalForm",
      "@context": {
        "@type": "xsd:string",
        "@vocab": "http://example.org/legalForms#",
        "LLC": "LLC",
        "Corporation": "Corporation",
        "LimitedPartnership": "Limited Partnership",
        "NonprofitCorporation": "Nonprofit Corporation",
        "GmbH": "GmbH",
        "AG": "AG",
        "Einzelunternehmen": "Einzelunternehmen",
        "GbR": "GbR",
        "OHG": "OHG",
        "KG": "KG",
        "UG": "UG",
        "SoleTrader": "Sole Trader",
        "UnincorporatedAssociation": "Unincorporated Association",
        "Partnership": "Partnership",
        "Trust": "Trust",
        "LimitedCompany": "Limited Company",
        "LLP": "LLP",
        "CIC": "CIC",
        "CIO": "CIO",
        "CooperativeSociety": "Cooperative Society",
        "BenCom": "BenCom",
        "other": "other"
      }
    },

    "ascs:Issuer": {
      "@id": "ascs:Issuer",
      "@context": {
        "member": {
          "@id": "schema:member",
          "@type": "@id"
        },
        "revocationRegistry": {
          "@id": "ascs:revocationRegistry",
          "@type": "xsd:anyURI",
          "rdfs:comment": "URI pointing to the revocation registry according to the specification in https://arxiv.org/abs/2501.17089."
        }
      }
    },

    "ascs:Participant": {
      "@id": "ascs:Participant",
      "rdfs:comment": "Participant entity representing a legal person or organization, compliant with mandatory Gaia-X standards for gx:LegalPerson.",
      "@context": {
        "@type": ["gx:LegalPerson", "schema:Organization"],
        "id": "@id",
        "revocationRegistryIndex": "ascs:revocationRegistryIndex",
        "legalName": "gx:legalName",
        "legalForm": "ascs:LegalForm",
        "headquartersAddress": {
          "@id": "gx:headquartersAddress",
          "@type": "gx:Address"
        },
        "legalAddress": {
          "@id": "gx:legalAddress",
          "@type": "gx:Address"
        },
        "registrationNumber": {
          "@id": "gx:registrationNumber",
          "@type": "gx:VatID"
        },
        "duns": "schema:duns",
        "email": "schema:email",
        "website": "schema:url",
        "termsOfSimpulseId": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Terms and conditions for SimpulseID application."
        }
      }
    },

    "ascs:BaseMembership": {
      "@id": "ascs:BaseMembership",
      "rdfs:comment": "Base membership entity. A revoked member credential type means no membership status.",
      "@context": {
        "@type": ["gx:LegalPerson", "schema:Organization"],
        "id": "@id",
        "revocationRegistryIndex": "ascs:revocationRegistryIndex",
        "memberSince": {
          "@id": "schema:memberSince",
          "@type": "xsd:date"
        },
        "termsAndConditions": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Terms and conditions for the base membership."
        }
      }
    },

    "ascs:EnvitedMembership": {
      "@id": "ascs:EnvitedMembership",
      "rdfs:comment": "Envited membership entity. A revoked member credential type means no membership status.",
      "@context": {
        "@type": ["ascs:LegalPerson", "schema:Organization"],
        "id": "@id",
        "revocationRegistryIndex": "ascs:revocationRegistryIndex",
        "memberSince": {
          "@id": "schema:memberSince",
          "@type": "xsd:date"
        },
        "termsAndConditions": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Terms and conditions for the Envited membership."
        }
      }
    },

    "ascs:Administrator": {
      "@id": "ascs:Administrator",
      "rdfs:comment": "Administrator entity representing a natural person, compliant with mandatory Gaia-X standards for gx:NaturalPerson.",
      "@context": {
        "@type": ["gx:NaturalPerson", "schema:Person"],
        "id": "@id",
        "revocationRegistryIndex": "ascs:revocationRegistryIndex",
        "memberOf": {
          "@id": "schema:memberOf",
          "@type": "@id",
          "@container": "@set",
          "rdfs:comment": "Array of IDs referencing participant and member types."
        },
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",
        "address": "gx:Address",
        "privacyPolicy": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Privacy policy for the administrator."
        }
      }
    },

    "ascs:User": {
      "@id": "ascs:User",
      "rdfs:comment": "User entity representing a natural person, compliant with mandatory Gaia-X standards for gx:NaturalPerson.",
      "@context": {
        "@type": ["gx:NaturalPerson", "schema:Person"],
        "id": "@id",
        "revocationRegistryIndex": "ascs:revocationRegistryIndex",
        "memberOf": {
          "@id": "schema:memberOf",
          "@type": "@id"
        },
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",
        "privacyPolicy": {
          "@id": "gx:TermsAndConditions",
          "rdfs:comment": "Privacy policy for the user."
        }
      }
    },

    "gx:Address": {
      "@context": {
        "streetAddress": "schema:streetAddress",
        "postalCode": "schema:postalCode",
        "addressLocality": "schema:addressLocality",
        "countrySubdivisionCode": "gx:countrySubdivisionCode",
        "country": "schema:addressCountry"
      }
    },

    "gx:VatID": {
      "@context": {
        "countryCode": {
          "@id": "gx:countryCode",
          "@type": "xsd:string"
        },
        "vatID": {
          "@id": "gx:vatID",
          "@type": "xsd:string"
        }
      }
    }
  }
}
