{
  "@context": {
    "@version": 1.1,
    "@protected": true,

    "ascs": "https://schema.ascs.digital/SimpulseId/v1#",
    "gx": "https://w3id.org/gaia-x/2411#",
    "schema": "https://schema.org/",
    
    "ascs:Issuer": {
      "@id": "ascs:Issuer",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "legalName": "gx:legalName",
        "applicationUrl": "schema:url"
      }
    },
    "ascs:Participant": {
      "@id": "ascs:Participant",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "@type": "gx:LegalPerson",
        "email": "schema:email",
        "duns": "schema:duns",
        "termsOfSimpulseId": "gx:TermsAndConditions"
      }
    },
    "ascs:BaseMembership": {
      "@id": "ascs:BaseMembership",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "@type": "gx:LegalPerson",
        "email": "schema:email",
        "duns": "schema:duns",
        "termsOfSimpulseId": "gx:TermsAndConditions"
      }
    },
    "ascs:EnvitedMembership": {
      "@id": "ascs:EnvitedMembership",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "@type": "ascs:LegalPerson",
        "email": "schema:email",
        "duns": "schema:duns",
        "termsOfSimpulseId": "gx:TermsAndConditions"
      }
    },
    "ascs:Administrator": {
      "@id": "ascs:Administrator",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "@type": "gx:NaturalPerson",
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",
        "address": "gx:Address",
        "privacyPolicy": "gx:TermsAndConditions"
      }
    },
    "ascs:User": {
      "@id": "ascs:User",
      "@context": {
        "@version": 1.1,
        "@protected": true,
        "@type": "gx:NaturalPerson",
        "givenName": "schema:givenName",
        "familyName": "schema:familyName",
        "email": "schema:email",
        "privacyPolicy": "gx:TermsAndConditions"
      }
    }
  }
}
