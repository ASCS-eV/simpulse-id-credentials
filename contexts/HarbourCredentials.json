{
    "@context": {
      "@version": 1.1,
      "@protected": true,
      "harbour": "https://schema.reachhaven.com/HarbourCredentials/v1#",
      "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
  
      "harbour:VerifiableCredential": {
        "@id": "harbour:VerifiableCredential",
        "rdfs:comment": "Credential issued through the Haven Harbour application.",
        "@context": {
          "@protected": true,
          "credentialStatus": {
            "@id": "harbour:CRSetEntry",
            "@container": "@set"
          }
        }
      },
  
      "harbour:CRSetEntry": {
        "@id": "harbour:CRSetEntry",
        "rdfs:comment": "Index in the revocation registry according to the specification in https://arxiv.org/abs/2501.17089.",
        "@context": {
          "@protected": true,
          "id": "@id",
          "type": "@type",
          "statusPurpose": "https://www.w3.org/ns/credentials/status#statusPurpose"
        }
      }
    }
}
